# ============================================================
# Server-Side Environment Variables
# ============================================================
# These credentials are used ONLY by the backend TURN token
# server (server/turn-server.js). They are NEVER sent to the
# browser. The frontend receives only ephemeral tokens
# generated via the Twilio Tokens API.
#
# Copy this file to .env and fill in your credentials.
# See TURN_SERVER_SETUP.md for full setup instructions.
# ============================================================

# Twilio API credentials (from https://console.twilio.com/)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ephemeral token lifetime in seconds (default: 3600 = 1 hour)
TURN_TOKEN_TTL=3600

# Backend server port (Vite dev proxy forwards /api/* here)
PORT=3001

# ============================================================
# Frontend Environment Variables
# ============================================================
# Production Lambda Function URL for TURN token generation.
# This is exposed to the browser (VITE_ prefix).
#
# For local development:
#   - Leave this commented out
#   - Vite proxy will forward /api/* to localhost:3001
#
# For production deployment:
#   - Uncomment and set to your Lambda Function URL
#   - Or use CloudFront + API Gateway with relative path /api/*
#
# VITE_TURN_API_URL=https://your-lambda-id.lambda-url.region.on.aws/api/turn-credentials
